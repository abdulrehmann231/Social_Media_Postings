# Google Drive
GOOGLE_SERVICE_ACCOUNT_JSON=<base64 encoded service account JSON key>
DRIVE_UNPOSTED_FOLDER_ID=<folder ID for new images to post>
DRIVE_POSTED_FOLDER_ID=<folder ID for already posted images>

# Groq (Caption Generation)
GROQ_API_KEY=<your Groq API key>

# LinkedIn
LINKEDIN_CLIENT_ID=<your LinkedIn app client ID>
LINKEDIN_CLIENT_SECRET=<your LinkedIn app client secret>
LINKEDIN_ACCESS_TOKEN=<obtained via /auth/linkedin flow>
LINKEDIN_REDIRECT_URI=https://your-app.onrender.com/auth/linkedin/callback
